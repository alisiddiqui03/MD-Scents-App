rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function adminUidList() {
      return [];
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // JWT claim OR hard-coded UIDs OR Firestore users/{uid}.role == 'admin' (matches app AuthService).
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.uid in adminUidList() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function productStockOnlyDecrease() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
        && request.resource.data.stock is int
        && resource.data.stock is int
        && request.resource.data.stock <= resource.data.stock
        && request.resource.data.stock >= 0;
    }

    // referralCode / referredBy: set once for owner; admin unrestricted via isAdmin() on update.
    function userReferralFieldsOk() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['referralCode'])
          || (!resource.data.keys().hasAny(['referralCode'])
              && request.resource.data.referralCode is string)
          || resource.data.referralCode == request.resource.data.referralCode)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['referredBy'])
            || (!resource.data.keys().hasAny(['referredBy'])
                && request.resource.data.referredBy is string)
            || resource.data.referredBy == request.resource.data.referredBy);
    }

    function userBirthdayFieldsOk() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      
      // 1. Birthday: set once
      let birthdayOk = !diff.hasAny(['birthday']) || (
        !resource.data.keys().hasAny(['birthday']) && request.resource.data.birthday is timestamp
      );

      // 2. Reward Flag: set once (false -> true)
      let rewardFlagOk = !diff.hasAny(['birthdayRewardGiven']) || (
        (!resource.data.keys().hasAny(['birthdayRewardGiven']) || resource.data.birthdayRewardGiven == false)
        && request.resource.data.birthdayRewardGiven == true
      );

      // 3. Discount Usage: increment or set once per year (we just ensure it's an int and doesn't go backwards)
      let discountYearOk = !diff.hasAny(['birthdayDiscountUsedYear']) || (
        request.resource.data.birthdayDiscountUsedYear is int
        && (!resource.data.keys().hasAny(['birthdayDiscountUsedYear']) || request.resource.data.birthdayDiscountUsedYear > resource.data.birthdayDiscountUsedYear)
      );

      return birthdayOk && rewardFlagOk && discountYearOk;
    }

    function userPointsFieldsOk() {
      let diff = request.resource.data.diff(resource.data).affectedKeys();
      // Owner can set points or update them via our app logic (transactions).
      return !diff.hasAny(['points']) || request.resource.data.points is number;
    }

    function oldWalletBalance() {
      return resource.data.keys().hasAny(['wallet'])
        && resource.data.wallet.keys().hasAny(['balance'])
        && resource.data.wallet.balance is number
        ? resource.data.wallet.balance
        : 0;
    }

    function oldWalletPending() {
      return resource.data.keys().hasAny(['wallet'])
        && resource.data.wallet.keys().hasAny(['pendingRewards'])
        && resource.data.wallet.pendingRewards is number
        ? resource.data.wallet.pendingRewards
        : 0;
    }

    // Owner: wallet balance only decreases; pending unchanged. Admin: any wallet change.
    function userWalletOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['wallet'])
        || isAdmin()
        || (request.resource.data.wallet.balance is number
            && request.resource.data.wallet.pendingRewards is number
            && request.resource.data.wallet.balance <= oldWalletBalance() + 0.001
            && request.resource.data.wallet.balance >= 0
            && request.resource.data.wallet.pendingRewards == oldWalletPending())
        || (request.resource.data.wallet.balance is number 
            && request.resource.data.wallet.balance == oldWalletBalance() + 250.0
            && request.resource.data.wallet.pendingRewards == oldWalletPending())
        || (request.resource.data.wallet.balance is number 
            && request.resource.data.wallet.balance == oldWalletBalance() + 50.0
            && request.resource.data.wallet.pendingRewards == oldWalletPending())
        || (request.resource.data.wallet.balance is number 
            && request.resource.data.wallet.balance == oldWalletBalance() + 2500.0
            && request.resource.data.wallet.pendingRewards == oldWalletPending());
    }

    function userOwnerUpdateOk() {
      return userReferralFieldsOk() && userWalletOk() && userBirthdayFieldsOk() && userPointsFieldsOk();
    }

    function orderClientUpdateOk() {
      let diffKeys = request.resource.data.diff(resource.data).affectedKeys();
      let hasCancel = diffKeys.hasAny(['cancellationUnreadForUser']);
      let hasReview = diffKeys.hasAny(['reviewSubmitted']);
      let hasOther = diffKeys.hasAny(request.resource.data.keys().removeAll(['cancellationUnreadForUser', 'reviewSubmitted']));
      
      return !hasOther 
          && (!hasCancel || request.resource.data.cancellationUnreadForUser == false)
          && (!hasReview || request.resource.data.reviewSubmitted == true);
    }

    function orderCreateClientOk() {
      return !request.resource.data.keys().hasAny([
        'referralServerProcessed',
        'walletDebitConfirmed',
        'walletDebitReversed'
      ]);
    }

    // Collection group queries (e.g. collectionGroup('orders') / collectionGroup('referrals')).
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{path=**}/reviews/{reviewId} {
      allow read: if isAdmin();
    }

    match /{path=**}/referrals/{referralId} {
      allow read: if isAdmin();
      allow update: if isAdmin();
    }

    match /orders/{orderId} {
      allow read, write: if false;
    }

    match /referralCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'createdAt']);
      allow update, delete: if false;
    }

    match /discounts/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // User submits VIP payment proof; admin verifies and activates.
    match /vipRequests/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.planType in ['monthly', 'yearly']
        && request.resource.data.status == 'pending'
        && request.resource.data.screenshotUrl is string
        && request.resource.data.keys().hasAll([
          'uid',
          'userName',
          'userEmail',
          'planType',
          'planPrice',
          'yearlySavingsPkr',
          'screenshotUrl',
          'status',
          'createdAt',
          'updatedAt'
        ]);

      // Owner: pending updates, or new pending submission after a previous approval (upgrade / re-pay).
      allow update: if isAdmin() || (
        isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.planType in ['monthly', 'yearly']
        && request.resource.data.status == 'pending'
        && request.resource.data.screenshotUrl is string
        && (!resource.data.keys().hasAny(['status'])
          || resource.data.status == 'pending'
          || resource.data.status == 'approved')
      );

      allow delete: if isAdmin();
    }

    // Perfume brand directory: anyone reads, admin manages.
    match /brands/{brandId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // OneSignal: admins mirror player id here so signed-in customers can read targets
    // for new-order push (cannot query users by role).
    match /admin_push_targets/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && request.auth.uid == uid;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && productStockOnlyDecrease());
    }

    match /products/{productId}/reviews/{authorUid} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && request.auth.uid == authorUid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && userOwnerUpdateOk());
      allow delete: if isAdmin() || isOwner(userId);

      match /orders/{orderId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId)
          && request.resource.data.userId == userId
          && orderCreateClientOk();
        allow update: if isAdmin() || (isOwner(userId) && orderClientUpdateOk());
        allow delete: if isAdmin() || isOwner(userId);
      }

      match /referrals/{referralId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn()
          && request.resource.data.referredUserId == request.auth.uid
          && request.resource.data.referrerUid == userId
          && request.resource.data.keys().hasAll([
            'referredUserId', 'referrerUid', 'orderId', 'status', 'rewardAmount', 'createdAt'
          ]);
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId);
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /reviews/{productId} {
        allow read, write: if isOwner(userId);
      }

      match /points_history/{historyId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }
  }
}
